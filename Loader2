<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <title>TMR LOADER v9.9</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background: #020617; color: #f8fafc; font-family: 'Inter', sans-serif; }
        .card { background: rgba(30, 41, 59, 0.5); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.05); border-radius: 24px; }
        .input-box { background: #0f172a; border: 1px solid #334155; color: #10b981; border-radius: 12px; }
        .input-box:focus { border-color: #10b981; box-shadow: 0 0 10px rgba(16,185,129,0.2); }
    </style>
</head>
<body class="p-4 max-w-md mx-auto pb-20">
    <header class="flex justify-between items-center mb-8 pt-4">
        <h1 class="text-2xl font-black text-emerald-500 italic">TMR<span class="text-white not-italic">LOADER</span></h1>
        <div id="clock" class="text-xs font-mono bg-emerald-500/10 text-emerald-400 px-3 py-1 rounded-full border border-emerald-500/20">00:00</div>
    </header>

    <form id="tmrForm" class="space-y-6">
        <div class="card p-4 space-y-3">
            <select id="opSel" required class="w-full input-box p-4 text-sm font-bold appearance-none"></select>
            <select id="shSel" required class="w-full input-box p-4 text-sm font-bold appearance-none">
                <option value="Pagi">SHIFT 1 (PAGI)</option><option value="Siang">SHIFT 2 (SIANG)</option><option value="Malam">SHIFT 3 (MALAM)</option>
            </select>
        </div>

        <div class="card p-4">
            <h3 class="text-[10px] uppercase font-black text-slate-500 mb-3 tracking-widest">Pilih Pen Tujuan</h3>
            <div id="pCon" class="space-y-2 max-h-44 overflow-y-auto pr-1"></div>
        </div>

        <div class="grid grid-cols-2 gap-3">
            <div class="card p-4 text-center border-b-4 border-emerald-500">
                <span class="text-[9px] text-slate-500 uppercase block mb-1">Target Sisa: <b id="t-sisa" class="text-white">0</b></span>
                <input type="number" id="a-sisa" placeholder="Aktual" class="w-full input-box p-3 text-center font-black">
            </div>
            <div class="card p-4 text-center border-b-4 border-emerald-500">
                <span class="text-[9px] text-slate-500 uppercase block mb-1">Target Odot: <b id="t-odot" class="text-white">0</b></span>
                <input type="number" id="a-odot" placeholder="Aktual" class="w-full input-box p-3 text-center font-black">
            </div>
            <div class="card p-4 text-center border-b-4 border-emerald-500">
                <span class="text-[9px] text-slate-500 uppercase block mb-1">Target Jagung: <b id="t-jagung" class="text-white">0</b></span>
                <input type="number" id="a-jagung" placeholder="Aktual" class="w-full input-box p-3 text-center font-black">
            </div>
            <div class="card p-4 text-center border-b-4 border-emerald-500">
                <span class="text-[9px] text-slate-500 uppercase block mb-1">Target Silase: <b id="t-silase" class="text-white">0</b></span>
                <input type="number" id="a-silase" placeholder="Aktual" class="w-full input-box p-3 text-center font-black">
            </div>
        </div>

        <div class="bg-emerald-600 p-6 rounded-[2rem] shadow-lg text-center">
            <span class="text-[10px] font-bold text-emerald-100 uppercase mb-1 block">Target Konsentrat</span>
            <div id="t-kon" class="text-6xl font-black mb-4">0</div>
            <input type="number" id="a-kon" placeholder="AKTUAL" class="w-full bg-black/20 border border-white/20 rounded-xl p-4 text-center font-black text-2xl text-white">
        </div>

        <div class="card p-6 space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <input type="number" id="m-s" placeholder="Awal" class="input-box p-4 text-center font-bold">
                <input type="number" id="m-a" placeholder="Akhir" class="input-box p-4 text-center font-bold">
            </div>
            <div class="flex justify-between items-center"><span class="text-xs font-bold text-emerald-500">HASIL MOLASES:</span><span class="text-2xl font-black"><span id="m-h">0</span> KG</span></div>
        </div>

        <button type="submit" id="btn" class="w-full bg-emerald-500 text-black font-black py-6 rounded-3xl text-xl shadow-lg active:scale-95 transition-all">SIMPAN & MULAI MIXING</button>
    </form>

    <script>
        const URL = "https://script.google.com/macros/s/AKfycbxr8WsQjjNzfSLVeZA07aVWoOO2nkcqVhIjub2L1WIbqL9zUdDcfcN2fj_98jT9i3JK/exec"; 
        let DB = null;

        async function init() {
            const res = await fetch(URL); DB = await res.json();
            const op = document.getElementById('opSel');
            op.innerHTML = '<option disabled selected>-- PILIH OPERATOR --</option>';
            DB.users.forEach(u => op.innerHTML += `<option value="${u}">${u}</option>`);
            render();
        }

        function render() {
            const sh = document.getElementById('shSel').value;
            const con = document.getElementById('pCon'); con.innerHTML = '';
            DB.pens.forEach(p => {
                let count = 0; DB.history.forEach(h => { if(h.shift === sh && h.pens.includes(p)) count++; });
                con.innerHTML += `<label class="flex justify-between p-4 card border-none items-center ${count>=2?'opacity-30':'hover:bg-slate-700/50'}">
                    <span class="font-bold text-sm text-slate-200">${p}</span>
                    <input type="checkbox" value="${p}" ${count>=2?'disabled':''} class="cb w-6 h-6 accent-emerald-500" onchange="calc()">
                </label>`;
            });
        }

        function calc() {
            const sh = document.getElementById('shSel').value;
            const sel = Array.from(document.querySelectorAll('.cb:checked')).map(c => c.value);
            let t = { s:0, o:0, j:0, si:0, k:0 };
            if(DB.targets) {
                let row = -1; for(let i=0; i<DB.targets.length; i++) { if(DB.targets[i][0] === sh) { row = i; break; } }
                if(row !== -1) {
                    sel.forEach(p => {
                        for(let j=row+1; j<DB.targets.length; j++) {
                            if(DB.targets[j][0] === p) {
                                t.s += parseFloat(DB.targets[j][1])||0; t.o += parseFloat(DB.targets[j][2])||0;
                                t.j += parseFloat(DB.targets[j][3])||0; t.si += parseFloat(DB.targets[j][4])||0;
                                t.k += parseFloat(DB.targets[j][5])||0; break;
                            }
                            if(["Pagi","Siang","Malam"].includes(DB.targets[j][0])) break;
                        }
                    });
                }
            }
            document.getElementById('t-sisa').innerText = Math.round(t.s); document.getElementById('t-odot').innerText = Math.round(t.o);
            document.getElementById('t-jagung').innerText = Math.round(t.j); document.getElementById('t-silase').innerText = Math.round(t.si);
            document.getElementById('t-kon').innerText = Math.round(t.k);
        }

        document.getElementById('m-s').oninput = document.getElementById('m-a').oninput = () => {
            let res = (parseFloat(document.getElementById('m-a').value)||0) - (parseFloat(document.getElementById('m-s').value)||0);
            document.getElementById('m-h').innerText = res > 0 ? Math.round(res) : 0;
        };

        document.getElementById('tmrForm').onsubmit = async (e) => {
            e.preventDefault(); const b = document.getElementById('btn'); b.disabled = true; b.innerText = "SENDING...";
            const p = { 
                formType: "loader", operator: document.getElementById('opSel').value, shift: document.getElementById('shSel').value, 
                pens: Array.from(document.querySelectorAll('.cb:checked')).map(c => c.value), 
                aktual: { sisa: document.getElementById('a-sisa').value, odot: document.getElementById('a-odot').value, jagung: document.getElementById('a-jagung').value, silase: document.getElementById('a-silase').value, konsentrat: document.getElementById('a-kon').value },
                molases: { sebelum: document.getElementById('m-s').value, akhir: document.getElementById('m-a').value, total: document.getElementById('m-h').innerText }
            };
            await fetch(URL, { method: 'POST', body: JSON.stringify(p) }); alert("BERHASIL!"); location.reload();
        };

        setInterval(() => { const n = new Date(); document.getElementById('clock').innerText = n.getHours().toString().padStart(2,'0') + ":" + n.getMinutes().toString().padStart(2,'0'); }, 1000);
        document.getElementById('shSel').onchange = render;
        window.onload = init;
    </script>
</body>
</html>